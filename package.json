{
  "name": "browser-agent",
  "displayName": "BrowserAgent",
  "description": "An AI-powered browser agent for VS Code",
  "version": "1.0.2",
  "publisher": "antigravity",
  "repository": {
    "type": "git",
    "url": "https://github.com/MohamedBouattour/coder-agent"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:browserAgent.run",
    "onView:browserAgent.panel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "browserAgent.run",
        "title": "Run Browser Agent"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "browserAgent",
          "title": "Browser Agent",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "browserAgent": [
        {
          "id": "browserAgent.panel",
          "type": "webview",
          "name": "Agent Prompt"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "compile-build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}
